MAUTIC_URL=https://your-mautic-domain.com
MAUTIC_USER=admin
MAUTIC_PASS=yourpassword

PORT=3000

# Public URL of this server (no trailing slash) — used in OAuth discovery
SERVER_URL=https://mcp.yourdomain.com

# Shared secret — anyone with this key can connect via claude.ai
MCP_API_KEY=change-this-to-a-secret-key
